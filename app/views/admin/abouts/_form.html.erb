<%= form_for [:admin, @about], html: {class: "form-horizontal"}  do |f| %>
  <div class="form-body">
    <div class="form-group">
      <%= f.label :title, class: "col-md-4 control-label" %>
      <div class="col-md-12">
         <%= f.text_field :title, class: "form-control input-circle",
                          placeholder: "Write title..." %>
      </div>
    </div>
     <div class ="form-group">
      <%= f.label :Avatar, class: "col-md-4 control-label" %>
      <div class="col-md-4">
        <%= f.file_field :image, class: "form-control input-circle" %>
        <%= f.hidden_field :image_cache %>
        </div>
        <% if @about.image? %>
          <div class="col-md-12">
            <%= image_tag @about.image.url, class: "image-thumb" %>
            <%= label_tag :remove_image do %>
              <%= f.check_box :remove_image %> Do not use photos
            <% end %>
          </div>
        <% end %>
    </div>
    <div class="form-group">
      <%= f.label :description, class: "col-md-4 control-label" %>
      <div class="col-md-12">
         <%= f.text_area :description, class: "form-control input-circle",
                           placeholder: "Write description..." %>
      </div>
    </div>
    <div class="form-group">
      <%= f.label :content, class: "col-md-4 control-label" %>
      <div class="col-md-12">
         <%= f.cktext_area :content, class: "form-control input-circle" %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit yield(:button_text)  , class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
