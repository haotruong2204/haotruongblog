<div class="container">
  <div class="book-title">
    <h1><%= @about.title %></h1>
  </div>
  <div class="book-content">
    <h4><%=raw @about.description %></h4>
    <%=raw @about.content %>
  </div>
  <% if @about.image? %>
    <%= image_tag @about.image.url %>
  <% end %>
  <div class="book-footer">
    <i class="fa fa-calendar"></i> ngày đăng : <%= @about.created_at.strftime(" %d-%m-%Y ") %>
  </div>
</div>
