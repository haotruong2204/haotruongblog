<tbody>
  <tr>
    <td class="col-sm-3"></i><%= link_to about.title , admin_about_path(about) %></td>
    <td><%=raw truncate(about.description , length: 30, omission: '...') %></td>
    <td><%=raw truncate(about.content , length: 30, omission: '...') %></td>
    <td></td>
    <td colspan="2">
      <%= link_to  admin_about_path(about), method: :delete, data: { confirm: "You sure?" } do %>
        <%= content_tag :i, "" , class: "fa fa-trash" %>
      <% end %>
      |
      <%= link_to edit_admin_about_path(about) do %>
        <%= content_tag :i, "", class: "fa fa-wrench" %>
      <% end %>
    </td>
  </tr>
</tbody>
