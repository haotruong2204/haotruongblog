<%= provide :title, "Hảo Trương | " + @post.title %>
<div class="post animated fadeInDown">
  <div class="about-title">
    <h2><i class="fab fa-twitter"></i> <%= @post.title %></h2>
  </div>
  <div class="about-content">
    <div class="description">
      <h4><%=raw @post.description %></h4>
    </div>
    <%=raw @post.content %>
  </div>
  <div class="book-footer">
    <i class="far fa-clock"></i><span class="date"> Ngày đăng : <%= @post.created_at.strftime(Settings.date.formats) %></span>
  </div>
</div>

